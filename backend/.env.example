# Backend environment variables
# Copy this file to .env and fill in real values

PORT=3000

# PostgreSQL connection (matches docker-compose service name 'db')
DB_HOST=db
DB_PORT=5432
DB_NAME=vestra_db
DB_USER=postgres
DB_PASSWORD=supersecret123

# In production on AWS, DB_HOST would be your RDS endpoint:
# DB_HOST=vestra-db.xxxxxxxx.eu-west-1.rds.amazonaws.com
